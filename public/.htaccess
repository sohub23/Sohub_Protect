<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # 1. Exclude the 'api' directory from being handled by the React SPA
  RewriteRule ^api/ - [L]

  # 2. If the file or directory exists, serve it directly
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 3. Otherwise, send everything else to index.html for React Router to handle
  RewriteRule ^ index.html [L]
</IfModule>
